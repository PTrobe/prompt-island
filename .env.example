# ─── LLM API Keys ────────────────────────────────────────────────────────────
# Required: Primary LLM provider for GPT-based agents (Machiavelli, Pedant, Floater)
OPENAI_API_KEY=your_openai_api_key_here

# Required: For Claude-based agents (Empath uses Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: For Llama-based agents (Chaos, Paranoid) via Groq's API
GROQ_API_KEY=your_groq_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, no setup required). Swap for PostgreSQL in production.
# SQLite:     sqlite:///./prompt_island.db
# PostgreSQL: postgresql://user:password@localhost:5432/prompt_island
DATABASE_URL=sqlite:///./prompt_island.db

# ─── Game Configuration ───────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
