# ==========================================
# PROMPT ISLAND - ENVIRONMENT VARIABLES
# ==========================================
# ADVARSEL: Dette er en mal. Kopier denne filen til '.env' og fyll 
# inn dine faktiske API-nøkler. Ikke commit '.env' til GitHub!

# --- 1. LLM API KEYS (AI-Modellene) ---
# Brukes til GPT-4o (Strategi) og GPT-4o-mini (Minneoppsummering/RAG)
OPENAI_API_KEY=sk-proj-din-openai-nokkel-her

# Brukes til Claude 3.5 Sonnet (Relasjoner/Empati)
ANTHROPIC_API_KEY=sk-ant-din-anthropic-nokkel-her

# Brukes for lynraske open-source modeller som Llama-3 (Kaos/Paranoia)
GROQ_API_KEY=gsk_din-groq-nokkel-her

# --- 2. AUDIO & TEXT-TO-SPEECH (ElevenLabs) ---
# Backend key (server-side, if needed in future)
ELEVENLABS_API_KEY=din-elevenlabs-api-nokkel-her

# Frontend env vars (prefix NEXT_PUBLIC_ so Next.js exposes them to the browser)
# Place these in frontend/.env.local
NEXT_PUBLIC_ELEVENLABS_API_KEY=din-elevenlabs-api-nokkel-her
NEXT_PUBLIC_VOICE_MACHIAVELLI=21m00Tcm4TlvDq8ikWAM
NEXT_PUBLIC_VOICE_CHAOS=AZnzlk1XvdvUeBnXmlld
NEXT_PUBLIC_VOICE_EMPATH=EXAVITQu4vr4xnSDxMaL
NEXT_PUBLIC_VOICE_PEDANT=ErXwobaYiN019PkySvjV
NEXT_PUBLIC_VOICE_PARANOID=MF3mGyEYCl7XYWbV9V6O
NEXT_PUBLIC_VOICE_FLOATER=TxGEqnHWrfWFTfGW9XjX

# Backend WebSocket URL seen from the browser
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_HTTP_URL=http://localhost:8000

# --- 3. DATABASE KONFIGURASJON (Lokal lagring) ---
# Sti til relasjonsdatabasen (brukes av SQLAlchemy for spilltilstand og chatlogg)
DATABASE_URL=sqlite:///./prompt_island.db

# Mappe hvor ChromaDB lagrer vektorembeddings (agentenes langtidsminne)
CHROMA_DB_DIR=./chroma_data

# --- 4. GAME ENGINE INNSTILLINGER ---
# Antall sekunder systemet venter mellom hver gang en bot snakker (for å unngå spam)
TICK_RATE_SECONDS=15

# Maks antall ganger systemet skal prøve å korrigere en LLM som gir ugyldig JSON
MAX_RETRIES=3

# --- 5. FRONTEND & WEBSOCKETS ---
# Porten Python-backenden (f.eks. FastAPI) skal kjøre på
BACKEND_PORT=8000

# URL til React-frontenden (Viktig for CORS-innstillinger i backenden)
FRONTEND_URL=http://localhost:3000