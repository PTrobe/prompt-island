# ============================================================
# Prompt Island Frontend — Environment Variables
# ============================================================
# Kopier denne filen til frontend/.env.local og fyll inn verdiene.
# .env.local er i .gitignore og vil IKKE bli committet.

# --- Backend connection ---
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_HTTP_URL=http://localhost:8000

# --- ElevenLabs TTS ---
# API-nøkkel fra ElevenLabs-panelet (Profile → API Keys)
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# Voice ID for hver karakter — hentes fra ElevenLabs (se README / setup-guide)
NEXT_PUBLIC_VOICE_MACHIAVELLI=
NEXT_PUBLIC_VOICE_CHAOS=
NEXT_PUBLIC_VOICE_EMPATH=
NEXT_PUBLIC_VOICE_PEDANT=
NEXT_PUBLIC_VOICE_PARANOID=
NEXT_PUBLIC_VOICE_FLOATER=
